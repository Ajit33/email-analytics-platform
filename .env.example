NODE_ENV=development
APP_BASE_URL=http://localhost:8000/api

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=NewsLetter
TYPEORM_SYNCHRONIZE=true

REDIS_HOST=127.0.0.1
REDIS_PORT=6379

JWT_SECRET=replace-with-strong-jwt-secret
TRACKING_TOKEN_SECRET=replace-with-strong-tracking-secret

MAILGUN_HOST=smtp.mailgun.org
MAILGUN_PORT=587
MAILGUN_USER=postmaster@example.com
MAILGUN_PASS=replace-with-mail-password
MAILGUN_FROM="Newsletter <no-reply@example.com>"

REPORT_REMINDER_TO=ops@example.com
DEFAULT_ORGANIZATION_ID=00000000-0000-0000-0000-000000000000
